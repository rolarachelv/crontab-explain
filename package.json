{
  "name": "crontab-explain",
  "version": "1.0.0",
  "description": "A terminal utility that parses cron expressions and outputs a human-readable schedule summary with next-run timestamps.",
  "main": "dist/cli.js",
  "bin": {
    "crontab-explain": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/cli.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["cron", "crontab", "cli", "scheduler", "terminal"],
  "author": "",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts"]
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
